modules = ["nodejs-22", "web"]
run = "npm run dev"
entrypoint = "src/app/(site)/page.tsx"
hidden = [".config", ".next", ".data", "node_modules"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 3000
externalPort = 80
